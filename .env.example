# ============================================================
#  LUMIÈRE — Variables d'environnement
#  Copiez ce fichier en .env pour le développement local
# ============================================================

# ── Serveur ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de données PostgreSQL ────────────────────────────────
# Render PostgreSQL, Supabase, Neon, Railway, etc.
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:motdepasse@localhost:5432/lumiere_db

# ── JWT ───────────────────────────────────────────────────────
# Générez une clé aléatoire longue :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REMPLACEZ_PAR_UNE_CLE_SECRETE_LONGUE_ET_ALEATOIRE
JWT_EXPIRES_IN=7d

# ── Admin ─────────────────────────────────────────────────────
# Le serveur hashera automatiquement ce mot de passe au démarrage
ADMIN_USERNAME=admin_lumiere
ADMIN_PASSWORD=lumi_ere/2025@*

# ── CORS ──────────────────────────────────────────────────────
# Origines autorisées, séparées par des virgules
# Exemple prod : https://votre-app.onrender.com
# Laissez vide pour autoriser toutes les origines (dev)
ALLOWED_ORIGINS=

# ── Cloudinary (stockage fichiers permanent) ──────────────────
# Créez un compte gratuit sur https://cloudinary.com
# Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret
